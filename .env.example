# OpenAI 兼容接口配置 (可对接 OpenAI / DeepSeek / Qwen / Kimi / 本地 vLLM 等)
# 复制本文件为 .env 并填入真实值

# 接口基础地址, 注意不要带末尾的 /chat/completions
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# 本地vLLM: http://localhost:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 模型名（默认模型，所有环节缺省都用它）
OPENAI_MODEL=gpt-4o-mini

# 可选：按角色分模型，各取所长（不填则回落到上面的 OPENAI_MODEL）
# 演戏用擅长角色扮演的模型，成书/谋篇用文笔与逻辑更强的模型。例如接 MiniMax：
# OPENAI_MODEL_CHARACTER=MiniMax-M2-her   # 角色即兴对话（角色扮演模型）
# OPENAI_MODEL_DIRECTOR=MiniMax-M2.5      # 导演造人/调度
# OPENAI_MODEL_NOVELIST=MiniMax-M3        # 执笔成书（最看重文笔与长文连贯）
# OPENAI_MODEL_REVIEWER=MiniMax-M3        # 成文后审校反射：评审挑刺（最看重逻辑与自洽；定向修订走 NOVELIST）
# OPENAI_MODEL_PLANNER=MiniMax-M3         # 规划大纲/修订
# OPENAI_MODEL_ARCHIVIST=MiniMax-M2.5     # 档案官抽取记忆（结构化）
# OPENAI_MODEL_EVAL=MiniMax-M3            # 评测裁判（LLM 评 LLM，建议用更强模型当裁判）

# 可选：MiniMax-M3 思考开关（仅 M3 生效；M2.x 忽略此项、思考始终开启）。
# 本项目会剥离并丢弃思考链，所以默认 disabled（跳过思考、直接作答，大幅提速省钱）。
#   disabled = 关思考（默认）；adaptive = 开思考（更慢，会生成随后被丢弃的推理）；off = 不发送该字段（非 MiniMax 端点用）
# OPENAI_THINKING=disabled
# 也可按角色单独开关，例如只给成文开思考以求文笔：
# OPENAI_THINKING_NOVELIST=adaptive

# 可选：成文后审校反射开关，默认开（评审挑刺 ⇄ 执笔人定向修订，主动修逻辑/常识/时间线/人设/既有事实硬伤）。
# 不需要或想省调用时设 off 关闭。
# OPENAI_REVIEW=off
# 可选：审校反射最多几轮（每轮 1 次挑刺 + 若有硬伤 1 次定向修订），默认 2；无硬伤会提前收。
# 设 1 只做一轮以省调用；设 0 等同关闭反射。
# OPENAI_REVIEW_ROUNDS=2

# 可选：瞬时错误（上游 529 过载 / 5xx 抖动 / 限流 / 网络中断）自动重试次数，默认 3。
# 重试用指数退避（约 1s/2s/4s…封顶 15s），避免整章生成因一次抖动中断。设 0 关闭重试。
# OPENAI_MAX_RETRIES=3
# 可选：单次请求超时（毫秒），默认 240000（4 分钟）。
# OPENAI_TIMEOUT_MS=240000
# 可选：【超时】专属重试次数（不含首次），默认 2；与 OPENAI_MAX_RETRIES 分开。
# 超时每重试一次都要再等一个 OPENAI_TIMEOUT_MS，故上限设得更小；设 0 = 超时不重试、立即失败。
# 注意：若是模型本就算不完（长文成文很慢），多重试无益，应改调大 OPENAI_TIMEOUT_MS 或换更快的模型。
# OPENAI_TIMEOUT_RETRIES=2
