{
  "name": "wuxia-novel",
  "version": "0.1.0",
  "description": "武侠剧场：多 Agent 即兴演出（导演调度）+ 执笔人成文 (Bun + TypeScript)",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "serve": "bun run src/server.ts",
    "web": "bun run --hot src/server.ts",
    "novel": "bun run src/novel.ts",
    "novel:next": "bun run src/novel.ts next",
    "novel:auto": "bun run src/novel.ts auto",
    "novel:list": "bun run src/novel.ts list",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
